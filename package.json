{
    "name": "maximo-script-deploy",
    "displayName": "Maximo Development Tools",
    "description": "An extension for developing and deploying Maximo automation scripts, forms, reports and screens from Visual Studio Code.",
    "publisher": "Sharptree",
    "version": "1.27.6",
    "galleryBanner": {
        "color": "#18242C",
        "theme": "dark"
    },
    "icon": "app-icon.png",
    "author": {
        "name": "Jason VenHuizen",
        "email": "jason.venhuizen@naviam.io"
    },
    "contributors": [
        {
            "name": "Chris Brown",
            "email": "chris.brown@naviam.io"
        }
    ],
    "bugs": {
        "url": "https://github.com/naviam-io/vscode-autoscript-deploy/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/naviam-io/vscode-autoscript-deploy"
    },
    "categories": [
        "Programming Languages",
        "Debuggers",
        "Other"
    ],
    "engines": {
        "vscode": "^1.90.0"
    },
    "activationEvents": [
        "onStartupFinished",
        "onDebug",
        "onDebugResolve:autoscript"
    ],
    "main": "./dist/extension",
    "contributes": {
        "snippets": [
            {
                "language": "javascript",
                "path": "./snippets/snippets_javascript.json"
            },
            {
                "language": "python",
                "path": "./snippets/snippets_python.json"
            }
        ],
        "configuration": {
            "title": "Maximo",
            "properties": {
                "naviam.maximo.customCA": {
                    "type": "string",
                    "default": null,
                    "editPresentation": "multilineText",
                    "description": "The full CA chain in PEM format."
                },
                "naviam.maximo.host": {
                    "type": "string",
                    "default": null,
                    "description": "The Maximo host name."
                },
                "naviam.maximo.user": {
                    "type": "string",
                    "default": null,
                    "description": "The Maximo user name."
                },
                "naviam.maximo.context": {
                    "type": "string",
                    "default": "maximo",
                    "description": "The Maximo URL context."
                },
                "naviam.maximo.extractLocation": {
                    "type": "string",
                    "default": "",
                    "description": "The Maximo script extraction location."
                },
                "naviam.maximo.extractScreenLocation": {
                    "type": "string",
                    "default": "",
                    "description": "The Maximo screens extraction location."
                },
                "naviam.maximo.extractInspectionFormsLocation": {
                    "type": "string",
                    "default": "",
                    "description": "The Maximo inspection forms extraction location."
                },
                "naviam.maximo.extractReportsLocation": {
                    "type": "string",
                    "default": "",
                    "description": "The Maximo BIRT reports extraction location."
                },
                "naviam.maximo.extractDBCLocation": {
                    "type": "string",
                    "default": "",
                    "description": "The Maximo DBC extraction location."
                },
                "naviam.maximo.port": {
                    "type": "number",
                    "default": 443,
                    "description": "The Maximo port number."
                },
                "naviam.maximo.debugPort": {
                    "type": "number",
                    "default": 4711,
                    "description": "The port for debugging Maximo automation scripts"
                },
                "naviam.maximo.useSSL": {
                    "type": "boolean",
                    "default": true,
                    "description": "Connect to Maximo using SSL?"
                },
                "naviam.maximo.timeout": {
                    "type": "number",
                    "default": 30,
                    "description": "The timeout in seconds.",
                    "minimum": 0,
                    "maximum": 300
                },
                "naviam.maximo.allowUntrustedCerts": {
                    "type": "boolean",
                    "default": false,
                    "description": "Allow untrusted SSL certificates."
                },
                "naviam.maximo.maxauthOnly": {
                    "type": "boolean",
                    "default": false,
                    "description": "Do not send Basic authentication header."
                },
                "naviam.maximo.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "The Maximo API Key."
                },
                "naviam.maximo.configurationTimeout": {
                    "type": "number",
                    "default": 5,
                    "description": "The Maximo script configuration timeout in minutes.",
                    "minimum": 0,
                    "maximum": 60
                },
                "naviam.maximo.logging.outputFile": {
                    "type": "string",
                    "default": "maximo.log",
                    "description": "The relative or absolute output log file path."
                },
                "naviam.maximo.logging.openEditorOnStart": {
                    "type": "boolean",
                    "default": true,
                    "description": "Open an editor to display the log file on start of log streaming."
                },
                "naviam.maximo.logging.append": {
                    "type": "boolean",
                    "default": false,
                    "description": "Append to the current log file."
                },
                "naviam.maximo.logging.follow": {
                    "type": "boolean",
                    "default": true,
                    "description": "Follow the log file when displayed in an editor."
                },
                "naviam.maximo.logging.timeout": {
                    "type": "number",
                    "default": 30,
                    "description": "Number of seconds between logging requests. The value should be no more than 30 seconds, to avoid server side timeouts."
                },
                "naviam.maximo.proxy.host": {
                    "type": "string",
                    "default": "",
                    "description": "The proxy host name."
                },
                "naviam.maximo.proxy.port": {
                    "type": "number",
                    "default": 3128,
                    "description": "The proxy port number."
                },
                "naviam.maximo.proxy.user": {
                    "type": "string",
                    "default": "",
                    "description": "The proxy username for proxy authentication."
                },
                "naviam.maximo.proxy.password": {
                    "type": "string",
                    "default": "",
                    "description": "The proxy password for proxy authentication."
                }
            }
        },
        "commands": [
            {
                "command": "maximo-script-deploy.deploy",
                "title": "Deploy to Maximo"
            },
            {
                "command": "maximo-script-deploy.extract",
                "title": "Extract Automation Scripts"
            },
            {
                "command": "maximo-script-deploy.compare",
                "title": "Compare with Maximo"
            },
            {
                "command": "maximo-script-deploy.screens",
                "title": "Extract Screen Definitions"
            },
            {
                "command": "maximo-script-deploy.id",
                "title": "Insert Unique Id for Maximo Presentation Tag"
            },
            {
                "command": "maximo-script-deploy.forms",
                "title": "Extract Inspection Forms"
            },
            {
                "command": "maximo-script-deploy.reports",
                "title": "Extract BIRT Reports"
            },
            {
                "command": "maximo-script-deploy.selectEnvironment",
                "title": "Select Maximo Environment"
            },
            {
                "command": "maximo-script-deploy.extractObject",
                "title": "Extract Maximo JSON"
            },
            {
                "command": "maximo-script-deploy.extractDBC",
                "title": "Extract Maximo DBC"
            },
            {
                "command": "maximo-script-deploy.tsTemplate",
                "title": "Initialize Maximo TypeScript Project"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "maximo-script-deploy.tsTemplate",
                    "when": "maximo-script-deploy.isNaviamUser"
                }
            ]
        },
        "keybindings": [
            {
                "command": "maximo-script-deploy.deploy",
                "key": "ctrl+alt+m",
                "mac": "ctrl+cmd+m",
                "when": "editorFocus"
            },
            {
                "command": "maximo-script-deploy.id",
                "key": "ctrl+alt+i",
                "mac": "ctrl+cmd+i",
                "when": "editorFocus"
            }
        ],
        "debuggers": [
            {
                "type": "autoscript",
                "label": "Maximo Automation Scripts",
                "languages": [
                    "python",
                    "javascript"
                ],
                "configurationAttributes": {
                    "attach": {
                        "properties": {
                            "name": {
                                "type": "string",
                                "default": "Attach to Maximo Automation Script"
                            },
                            "request": {
                                "type": "string",
                                "enum": [
                                    "attach"
                                ],
                                "default": "attach"
                            },
                            "type": {
                                "type": "string",
                                "enum": [
                                    "autoscript"
                                ],
                                "default": "autoscript"
                            },
                            "scriptRoots": {
                                "type": "array",
                                "description": "Local folders containing automation scripts to map back from Maximo script names.",
                                "items": {
                                    "type": "string"
                                },
                                "default": [
                                    "${workspaceFolder}"
                                ]
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "autoscript",
                        "request": "attach",
                        "name": "Attach to Maximo Automation Script",
                        "scriptRoots": [
                            "${workspaceFolder}"
                        ]
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "Attach to Maximo Automation Script",
                        "description": "Attach to the Maximo Automation Script debugger running inside the Maximo JVM.",
                        "body": {
                            "type": "autoscript",
                            "request": "attach",
                            "name": "Attach to Maximo Automation Script",
                            "scriptRoots": [
                                "${workspaceFolder}"
                            ]
                        }
                    }
                ]
            }
        ]
    },
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "node ./test/runTest.js",
        "webpack": "webpack --mode production",
        "webpack-dev": "webpack --mode development --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "vscode:prepublish": "npm run package",
        "vsce:package": "vsce package"
    },
    "devDependencies": {
        "@types/glob": "^7.1.4",
        "@types/mocha": "^9.1.1",
        "@types/node": "^14.18.48",
        "@types/vscode": "^1.75.0",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^8.57.1",
        "glob": "^7.2.3",
        "mocha": "^7.2.0",
        "typescript": "^4.9.5",
        "webpack": "^5.100.2",
        "webpack-cli": "^4.10.0"
    },
    "dependencies": {
        "archiver": "^7.0.1",
        "axios": "^1.10.0",
        "axios-oauth-client": "^1.5.0",
        "axios-token-interceptor": "^0.2.0",
        "is-valid-hostname": "^1.0.2",
        "punycode": "^2.3.1",
        "readline": "^1.3.0",
        "semver": "^7.7.2",
        "temp": "^0.9.4",
        "text-encoding": "^0.7.0",
        "tough-cookie": "^4.1.2",
        "uuid": "^10.0.0",
        "webpack-node-externals": "^3.0.0",
        "xml-formatter": "^2.6.1",
        "xml2js": "^0.6.0",
        "yauzl": "^3.2.0"
    }
}
