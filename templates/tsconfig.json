{
    "compilerOptions": {
        "target": "ES5",
        "module": "ES2015",
        "lib": ["ES5", "ES2015.Promise", "ES2015"],
        "allowJs": true,
        "checkJs": false,
        "outDir": "./dist",
        "rootDir": "./src",
        "removeComments": true,
        "noEmit": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": false,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "types": []
    },
    "include": ["src/**/*", "nashorn.d.ts"],
    "exclude": ["node_modules", "dist"]
}